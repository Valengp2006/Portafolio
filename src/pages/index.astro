---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";

const base = import.meta.env.BASE_URL;

const muse = projects.find((p) => p.slug === "muse")!;
const pasos = projects.find((p) => p.slug === "pasos-de-tradicion")!;
const cosmos = projects.find((p) => p.slug === "cosmos")!;
const luna = projects.find((p) => p.slug === "luna-y-las-estrellas-perdidas")!;

const areas = [
  { n: "01", title: "Diseño de experiencias interactivas", body: "Diseño instalaciones, interfaces y sistemas participativos donde la tecnología responde a las acciones de las personas para construir experiencias compartidas." },
  { n: "02", title: "Patrimonio cultural digital", body: "Desarrollo experiencias que utilizan medios digitales para documentar, preservar y reinterpretar el patrimonio cultural desde una perspectiva participativa e inmersiva." },
  { n: "03", title: "UI/UX Research & Design", body: "Diseño productos digitales centrados en las personas mediante investigación, arquitectura de información, prototipado y evaluación continua de la experiencia." },
];
---

<Layout title="Valentina — Diseño de experiencias interactivas">
  <Nav active="" />
  <main>
    <!-- Se eliminan las clases .wrap de todas las secciones -->
    <section class="hero">
      <div class="hero-info">
        <p class="eyebrow reveal">Portafolio</p>
        <h1 class="hero-title reveal">Diseño de <span>experiencias</span><br />interactivas</h1>
        <div class="hero-personal reveal">
          <p class="hero-name">Valentina</p>
          <p class="hero-role">Estudiante de Ingeniería en Diseño de Entretenimiento Digital · UPB</p>
          <p class="hero-bio">Diseño experiencias donde la interacción se convierte en una forma de contar historias, preservar memorias y acercar a las personas a la tecnología. Mi trabajo combina investigación, diseño y desarrollo para crear proyectos que conectan lo digital con lo cultural, lo participativo y lo humano.</p>
          <div class="hero-links">
            <a href={`${base}sobre-mi/`.replace(/\/\/+/g, '/')} class="link-underline">Sobre mí ↗</a>
            <a href={`${base}proyectos/`.replace(/\/\/+/g, '/')} class="link-underline">Ver todos los proyectos ↗</a>
          </div>
        </div>
      </div>
      <div class="hero-photo reveal">
        <img src={`${base}images/valentina.jpg`.replace(/\/\/+/g, '/')} alt="Retrato de Valentina" />
      </div>
    </section>

    <section class="quote reveal">
      <p class="quote-text">"Los que hacen posible la procesión rara vez aparecen en las fotografías."</p>
      <p class="quote-source">— hallazgo central de investigación, <a href={`${base}proyectos/pasos-de-tradicion/`.replace(/\/\/+/g, '/')} class="link-underline">Pasos de Tradición</a></p>
    </section>

    <section class="way-of-designing">
      <p class="way-title">Mi forma de diseñar</p>
      <p class="way-body">No empiezo un proyecto pensando en la tecnología que voy a utilizar. Empiezo con una <em>pregunta</em>.</p>
      <p class="way-body">¿Cómo puede una interfaz acercar a las personas a una historia? ¿Cómo puede una experiencia interactiva preservar una tradición? ¿Cómo puede un sistema invitar a participar en lugar de observar?</p>
      <p class="way-body">A partir de esas preguntas combino <em>investigación, diseño y desarrollo</em> para construir experiencias donde la tecnología deja de ser el centro y se convierte en un medio para <em>conectar personas, ideas y memorias.</em></p>
    </section>

    <section class="featured">
      <div class="featured-head">
        <div>
          <p class="eyebrow reveal">Proyectos destacados</p>
          <h2 class="featured-heading reveal">Una selección de trabajo reciente</h2>
        </div>
        <a href={`${base}proyectos/`.replace(/\/\/+/g, '/')} class="link-underline featured-all">Ver todos ↗</a>
      </div>
      <div class="featured-cards">
        <div class="reveal"><ProjectCard project={muse} layout="hero" /></div>
        <div class="featured-pair">
          <div class="reveal"><ProjectCard project={pasos} layout="vertical" /></div>
          <div class="reveal"><ProjectCard project={cosmos} layout="vertical" /></div>
        </div>
        <div class="reveal"><ProjectCard project={luna} layout="horizontal" /></div>
      </div>
    </section>

    <section class="areas">
      <p class="eyebrow reveal">Áreas de Trabajo</p>
      <div class="areas-grid reveal">
        {areas.map((a) => (
          <div class="area">
            <p class="area-n">{a.n}</p>
            <p class="area-title">{a.title}</p>
            <p class="area-body">{a.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="contact">
      <p class="contact-title reveal">¿Trabajamos un poco?</p>
      <p class="contact-body reveal">Disponible para proyectos de diseño de experiencias, patrimonio cultural y UI/UX.</p>
      <a href="mailto:valentinagp2006@gmail.com" class="link-underline contact-email reveal">valentinagp2006@gmail.com ↗</a>
    </section>
  </main>
  <Footer />

  <style>
    /* Se estandariza el padding: 45px 155px; en todas las secciones principales */
    .hero { display: flex; align-items: flex-end; justify-content: space-between; gap: 40px; padding: 45px 155px; height: auto; }
    .hero-info { max-width: 860px; }
    .hero-title { font-family: var(--font-display); font-weight: 400; font-size: 72px; line-height: 1; letter-spacing: -1.44px; margin: 10px 0 42px; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .hero-personal { display: flex; flex-direction: column; gap: 6px; }
    .hero-name { font-family: var(--font-display); font-weight: 600; font-size: 24px; margin: 0; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .hero-role { font-size: 16px; color: var(--ink-muted); margin: 0 0 8px; }
    .hero-bio { font-size: 18px; color: var(--ink-soft); line-height: 1.65; margin: 0 0 20px; max-width: 62ch; }
    .hero-links { display: flex; gap: 24px; font-size: 16px; }
    .hero-photo { width: 204px; height: 254px; border-radius: 16px; overflow: hidden; background: var(--line); flex-shrink: 0; }
    .hero-photo img { width: 100%; height: 100%; object-fit: cover; }
    @media (max-width: 1000px) {
      .hero { flex-direction: column; align-items: flex-start; padding: 40px 20px; }
      .hero-title { font-size: 44px; }
      .hero-photo { order: -1; margin-bottom: 24px; }
    }

    .quote { background: var(--ink); color: #ffffff; padding: 45px 155px; }
    .quote-text { font-family: var(--font-display); font-weight: 400; font-size: 42px; line-height: 1.14; letter-spacing: -0.42px; margin: 0 0 12px; max-width: 22ch; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .quote-source { font-size: 12px; color: var(--ink-muted); margin: 0; }
    .quote-source a { color: #ffffff; }
    @media (max-width: 900px) { .quote { padding: 32px 20px; } }

    .way-of-designing { background: var(--line); padding: 45px 155px; }
    .way-title { font-family: var(--font-display); font-weight: 400; font-size: 32px; margin: 0 0 21px; letter-spacing: -0.16px; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .way-body { font-size: 18px; color: var(--ink-soft); line-height: 1.65; max-width: 900px; margin: 0 0 14px; }
    .way-body em { color: var(--ink); font-style: italic; font-weight: 600; }
    @media (max-width: 760px) { .way-of-designing { padding: 32px 20px; } }

    .featured { padding: 45px 155px; }
    .featured-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 32px; }
    .featured-heading { font-family: var(--font-display); font-weight: 400; font-size: 32px; margin: 12px 0 0; letter-spacing: -0.16px; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .featured-all { font-size: 16px; white-space: nowrap; }
    .featured-cards { display: flex; flex-direction: column; gap: 31px; }
    .featured-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    @media (max-width: 900px) {
      .featured { padding: 32px 20px; }
      .featured-pair { grid-template-columns: 1fr; }
      .featured-head { flex-direction: column; align-items: flex-start; }
    }

    .areas { background: var(--line); padding: 45px 155px; }
    .areas-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 38px; }
    .area-n { font-size: 12px; color: var(--ink-muted); margin: 0 0 16px; }
    .area-title { font-family: var(--font-display); font-weight: 600; font-size: 24px; margin: 0 0 16px; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .area-body { font-size: 16px; color: var(--ink-soft); line-height: 1.75; margin: 0; }
    @media (max-width: 900px) {
      .areas { padding: 32px 20px; }
      .areas-grid { grid-template-columns: 1fr; gap: 28px; }
    }

    .contact { padding: 45px 155px 96px; }
    .contact-title { font-family: var(--font-display); font-weight: 400; font-size: 42px; letter-spacing: -0.42px; margin: 0 0 20px; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .contact-body { font-size: 18px; color: var(--ink-soft); margin: 0 0 20px; }
    .contact-email { font-size: 16px; }
    @media (max-width: 900px) { .contact { padding: 32px 20px 64px; } }
  </style>
</Layout>
