---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const info = [
  { label: "Ubicación", body: "Medellín, Colombia" },
  { label: "Disponibilidad", body: "Disponible para oportunidades laborales, colaboraciones y proyectos freelance." },
  { label: "Enfoque", body: "UX/UI · Interacción · Tecnología creativa" },
];
---

<Layout title="Contacto — Valentina">
  <Nav active="contacto" />
  <main>
    <section class="hero">
      <div class="wrap hero-wrap">
        <p class="eyebrow reveal">Contacto</p>
        <h1 class="hero-title reveal">¿Trabajamos un poco?</h1>
        <div class="hero-info reveal">
          <p class="hero-body">¿Tienes una idea, un proyecto o un reto de diseño? Me interesa colaborar en experiencias digitales, productos interactivos e iniciativas que conecten tecnología, cultura y personas. Conversemos.</p>
          <a href="mailto:vgarzonp2006@gmail.com" class="link-underline">vgarzonp2006@gmail.com ↗</a>
        </div>
      </div>
    </section>

    <section class="info-row">
      <div class="wrap info-wrap reveal">
        {info.map((i) => (
          <div class="info-item">
            <h3 class="info-label">{i.label}</h3>
            <p class="info-body">{i.body}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />

  <style>
    /* VARIABLES EXACTAS DE FIGMA */
    :root {
      --figma-dark: #1F1B16;
      --figma-bg: #E4DFD6;
      --figma-muted: #8A837A;
      --figma-soft: #57504A;
      --font-fraunces: 'Fraunces', serif;
      --font-inter: 'Inter', sans-serif;
    }

    /* CONTENEDOR GLOBAL */
    .wrap {
      max-width: 1513px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
    }

    .eyebrow {
      font-family: var(--font-fraunces);
      font-weight: 600;
      font-size: 18px;
      line-height: 26px;
      color: var(--figma-muted);
      margin: 0 0 16px 0;
    }

    /* --- HERO --- */
    .hero { border-bottom: 1px solid var(--figma-bg); }
    .hero-wrap { 
      padding: 64px 155px; 
      display: flex; 
      flex-direction: column; 
    }
    .hero-title { 
      font-family: var(--font-fraunces); 
      font-weight: 400; 
      font-size: 72px; 
      line-height: 72px;
      color: var(--figma-dark); 
      margin: 0 0 24px 0; 
    }
    .hero-info { 
      display: flex; 
      flex-direction: column; 
      gap: 24px; 
      max-width: 900px; 
    }
    .hero-body { 
      font-family: var(--font-inter);
      font-size: 18px; 
      line-height: 30px;
      color: var(--figma-soft); 
      margin: 0; 
    }
    .link-underline {
      font-family: var(--font-inter);
      font-size: 16px;
      font-weight: 500;
      line-height: 24px;
      color: var(--figma-dark);
      text-decoration: underline;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    /* --- INFO ROW --- */
    .info-row { border-bottom: 1px solid var(--figma-bg); }
    .info-wrap { 
      padding: 45px 98px; /* Padding exacto de Figma para esta barra inferior */
      display: flex; 
      justify-content: space-between; 
      gap: 40px; 
    }
    .info-item { 
      display: flex; 
      flex-direction: column; 
      gap: 8px; 
    }
    /* El segundo ítem (Disponibilidad) es más ancho en Figma */
    .info-item:nth-child(2) {
      max-width: 520px;
    }
    .info-label { 
      font-family: var(--font-fraunces); 
      font-weight: 600; 
      font-size: 24px; 
      line-height: 32px;
      color: var(--figma-muted); 
      margin: 0; 
    }
    .info-body { 
      font-family: var(--font-inter);
      font-size: 18px; 
      line-height: 30px;
      color: var(--figma-dark); 
      margin: 0; 
    }

    /* RESPONSIVIDAD */
    @media (max-width: 1000px) {
      .hero-wrap { padding: 40px 20px; }
      .hero-title { font-size: 44px; line-height: 50px; }
      .info-wrap { padding: 40px 20px; flex-direction: column; gap: 32px; }
    }
  </style>
</Layout>
