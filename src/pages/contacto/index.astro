---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const info = [
  { label: "Ubicación", body: "Medellín, Colombia" },
  { label: "Disponibilidad", body: "Disponible para oportunidades laborales, colaboraciones y proyectos freelance." },
  { label: "Enfoque", body: "UX/UI · Interacción · Tecnología creativa" },
];
---

<Layout title="Contacto — Valentina">
  <Nav active="contacto" />
  <main>
    <section class="hero wrap">
      <p class="eyebrow reveal">Contacto</p>
      <h1 class="hero-title reveal">¿Trabajamos un poco?</h1>
      <div class="hero-info reveal">
        <p class="hero-body">¿Tienes una idea, un proyecto o un reto de diseño? Me interesa colaborar en experiencias digitales, productos interactivos e iniciativas que conecten tecnología, cultura y personas. Conversemos.</p>
        <a href="mailto:vgarzonp2006@gmail.com" class="link-underline">vgarzonp2006@gmail.com ↗</a>
      </div>
    </section>

    <section class="info-row wrap reveal">
      {info.map((i) => (
        <div class="info-item">
          <p class="info-label">{i.label}</p>
          <p class="info-body">{i.body}</p>
        </div>
      ))}
    </section>
  </main>
  <Footer />

  <style>
    .hero { padding: 64px 155px; border-bottom: 1px solid var(--line); }
    .hero-title { font-family: var(--font-display); font-weight: 400; font-size: 72px; line-height: 1; letter-spacing: -1.44px; margin: 0 0 58px; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .hero-info { display: flex; flex-direction: column; gap: 24px; max-width: 900px; }
    .hero-body { font-size: 18px; color: var(--ink-soft); margin: 0; line-height: 1.65; }

    .info-row { padding: 45px 98px; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); display: flex; gap: 48px; }
    .info-label { font-family: var(--font-display); font-weight: 600; font-size: 24px; margin: 0 0 8px; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .info-body { font-size: 18px; color: var(--ink); margin: 0; max-width: 32ch; }

    @media (max-width: 1000px) {
      .hero { padding: 40px 20px; }
      .hero-title { font-size: 40px; }
      .info-row { padding: 32px 20px; flex-direction: column; gap: 24px; }
    }
  </style>
</Layout>
