---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

// Ruta base para GitHub Pages
const base = import.meta.env.BASE_URL;

const herramientas = [["Figma", "FigJam", "Canva"], ["CapCut", "Notion", "Reaper"], ["GitHub", "Unity", "TouchDesigner"]];
const habilidades = [["Investigación UX", "Diseño de interacción"], ["Diseño de interfaces", "Prototipado"], ["Diseño de experiencias", "Medios interactivos"], ["Narrativa digital", "Investigación cultural"]];
const idiomas = ["Español (Nativo)", "Inglés (B2)"];
---

<Layout title="Sobre mí — Valentina">
  <Nav active="sobre-mi" />
  <main>
    <section class="hero">
      <div class="wrap hero-wrap">
        <div class="hero-info">
          <p class="eyebrow reveal">Sobre mí</p>
          <h1 class="hero-title reveal">Diseñadora, investigadora, narradora</h1>
          <div class="hero-body reveal">
            <p>Soy Valentina, estudiante de Ingeniería en Diseño de Entretenimiento Digital en la Universidad Pontificia Bolivariana (UPB). Me interesa diseñar experiencias donde la investigación, la tecnología y la narrativa trabajan juntas para acercar a las personas a nuevas formas de interactuar con el conocimiento, la cultura y el entorno.</p>
            <p>Mi trabajo se desarrolla en la intersección de la cultura, la tecnología y el diseño. Me interesa especialmente el patrimonio cultural digital: cómo las comunidades pueden ser protagonistas de sus propios archivos, no sólo sujetos de documentación.</p>
            <p>Cada proyecto comienza con una pregunta de investigación. A partir de ella combino trabajo de campo, diseño de interacción y desarrollo de prototipos para construir experiencias donde la tecnología deja de ser el centro y se convierte en una herramienta para comunicar, preservar o generar nuevas formas de participación.</p>
            <a href={`${base}contacto/`.replace(/\/\/+/g, '/')} class="link-underline">Conversemos ↗</a>
          </div>
        </div>
        <div class="hero-photo reveal">
          <img src={`${base}images/valentina-full.jpg`.replace(/\/\/+/g, '/')} alt="Retrato de Valentina" />
        </div>
      </div>
    </section>

    <section class="skills">
      <div class="wrap skills-wrap">
        <p class="eyebrow reveal">Habilidades y Herramientas</p>
        <div class="skills-grid reveal">
          <div class="skill-col">
            <h3 class="skill-title">Herramientas</h3>
            {herramientas.map((row) => (
              <div class="skill-row">
                {row.map((t) => <span class="tag-pill">{t}</span>)}
              </div>
            ))}
          </div>
          <div class="skill-col">
            <h3 class="skill-title">Habilidades</h3>
            {habilidades.map((row) => (
              <div class="skill-row">
                {row.map((t) => <span class="tag-pill">{t}</span>)}
              </div>
            ))}
          </div>
          <div class="skill-col skill-col-narrow">
            <h3 class="skill-title">Idiomas</h3>
            {idiomas.map((t) => (
              <div class="skill-row"><span class="tag-pill">{t}</span></div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <style>
    /* VARIABLES EXACTAS DE FIGMA */
    :root {
      --figma-dark: #1F1B16;
      --figma-bg: #E4DFD6;
      --figma-neutral-100: #F5F1EA;
      --figma-muted: #8A837A;
      --figma-soft: #57504A;
      --font-fraunces: 'Fraunces', serif;
      --font-inter: 'Inter', sans-serif;
    }

    /* CONTENEDOR GLOBAL RESPONSIVO */
    .wrap {
      max-width: 1513px;
      margin: 0 auto;
      padding: 45px 155px;
      width: 100%;
      box-sizing: border-box;
    }
    @media (max-width: 1000px) {
      .wrap { padding: 40px 20px; }
    }

    .eyebrow {
      font-family: var(--font-fraunces);
      font-weight: 600;
      font-size: 18px;
      line-height: 26px;
      color: var(--figma-muted);
      margin: 0 0 16px 0;
    }

    /* --- HERO --- */
    .hero { border-bottom: 1px solid var(--figma-bg); }
    .hero-wrap { 
      display: flex; 
      align-items: center; 
      justify-content: space-between; 
      gap: 40px; 
    }
    .hero-info { max-width: 860px; }
    .hero-title { 
      font-family: var(--font-fraunces); 
      font-weight: 400; 
      font-size: 56px; 
      line-height: 60px; 
      color: var(--figma-dark);
      margin: 0 0 24px 0; 
    }
    .hero-body p { 
      font-family: var(--font-inter);
      font-size: 18px; 
      line-height: 30px; 
      color: var(--figma-soft); 
      margin: 0 0 24px 0; 
    }
    .link-underline {
      font-family: var(--font-inter);
      font-size: 16px;
      font-weight: 500;
      color: var(--figma-dark);
      text-decoration: underline;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 8px;
    }
    .hero-photo { 
      width: 268px; 
      height: 333px; 
      border-radius: 16px; 
      overflow: hidden; 
      background: var(--figma-bg); 
      flex-shrink: 0; 
    }
    .hero-photo img { width: 100%; height: 100%; object-fit: cover; }
    
    @media (max-width: 1000px) {
      .hero-wrap { flex-direction: column; align-items: flex-start; }
      .hero-title { font-size: 40px; line-height: 48px; }
      .hero-photo { order: -1; margin-bottom: 24px; width: 100%; max-width: 268px; }
    }

    /* --- SKILLS --- */
    .skills-wrap { padding-top: 45px; padding-bottom: 90px; }
    .skills-grid { 
      display: grid; 
      grid-template-columns: 2fr 2fr 1fr; 
      gap: 40px; 
      margin-top: 51px; 
    }
    .skill-title { 
      font-family: var(--font-fraunces); 
      font-weight: 600; 
      font-size: 24px; 
      line-height: 32px;
      color: var(--figma-dark);
      margin: 0 0 29px 0; 
    }
    .skill-row { 
      display: flex; 
      gap: 8px; 
      margin-bottom: 16px; 
      flex-wrap: wrap; 
    }
    
    /* ESTILOS EXACTOS DE LOS TAGS DE FIGMA */
    .tag-pill {
      font-family: var(--font-inter);
      font-size: 16px;
      line-height: 28px;
      color: var(--figma-soft);
      background-color: var(--figma-neutral-100);
      border: 1px solid var(--figma-bg);
      border-radius: 100px;
      padding: 4px 24px;
      display: inline-block;
    }

    @media (max-width: 900px) {
      .skills-grid { grid-template-columns: 1fr; gap: 40px; margin-top: 32px; }
    }
  </style>
</Layout>
