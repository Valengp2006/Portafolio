---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const herramientas = [["Figma", "FigJam", "Canva"], ["CapCut", "Notion", "Reaper"], ["GitHub", "Unity", "TouchDesigner"]];
const habilidades = [["Investigación UX", "Diseño de interacción"], ["Diseño de interfaces", "Prototipado"], ["Diseño de experiencias", "Medios interactivos"], ["Narrativa digital", "Investigación cultural"]];
const idiomas = ["Español (Nativo)", "Inglés (B2)"];
---

<Layout title="Sobre mí — Valentina">
  <Nav active="sobre-mi" />
  <main>
    <section class="hero wrap">
      <div class="hero-info">
        <p class="eyebrow reveal">Sobre mí</p>
        <h1 class="hero-title reveal">Diseñadora, investigadora, narradora</h1>
        <div class="hero-body reveal">
          <p>Soy Valentina, estudiante de Ingeniería en Diseño de Entretenimiento Digital en la Universidad Pontificia Bolivariana (UPB). Me interesa diseñar experiencias donde la investigación, la tecnología y la narrativa trabajan juntas para acercar a las personas a nuevas formas de interactuar con el conocimiento, la cultura y el entorno.</p>
          <p>Mi trabajo se desarrolla en la intersección de la cultura, la tecnología y el diseño. Me interesa especialmente el patrimonio cultural digital: cómo las comunidades pueden ser protagonistas de sus propios archivos, no sólo sujetos de documentación.</p>
          <p>Cada proyecto comienza con una pregunta de investigación. A partir de ella combino trabajo de campo, diseño de interacción y desarrollo de prototipos para construir experiencias donde la tecnología deja de ser el centro y se convierte en una herramienta para comunicar, preservar o generar nuevas formas de participación.</p>
          <a href="/contacto/" class="link-underline">Conversemos ↗</a>
        </div>
      </div>
      <div class="hero-photo reveal">
        <img src="/images/valentina-full.jpg" alt="Retrato de Valentina" />
      </div>
    </section>

    <section class="skills wrap">
      <p class="eyebrow reveal">Habilidades y Herramientas</p>
      <div class="skills-grid reveal">
        <div class="skill-col">
          <p class="skill-title">Herramientas</p>
          {herramientas.map((row) => (
            <div class="skill-row">
              {row.map((t) => <span class="tag-pill">{t}</span>)}
            </div>
          ))}
        </div>
        <div class="skill-col">
          <p class="skill-title">Habilidades</p>
          {habilidades.map((row) => (
            <div class="skill-row">
              {row.map((t) => <span class="tag-pill">{t}</span>)}
            </div>
          ))}
        </div>
        <div class="skill-col skill-col-narrow">
          <p class="skill-title">Idiomas</p>
          {idiomas.map((t) => (
            <div class="skill-row"><span class="tag-pill">{t}</span></div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <style>
    .hero { display: flex; align-items: center; justify-content: space-between; gap: 40px; padding: 64px 155px; border-bottom: 1px solid var(--line); }
    .hero-info { max-width: 860px; }
    .hero-title { font-family: var(--font-display); font-weight: 400; font-size: 56px; line-height: 1.07; letter-spacing: -0.56px; margin: 0 0 34px; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .hero-body p { font-size: 18px; color: var(--ink-soft); line-height: 1.65; margin: 0 0 20px; }
    .hero-photo { width: 268px; height: 333px; border-radius: 16px; overflow: hidden; background: var(--line); flex-shrink: 0; }
    .hero-photo img { width: 100%; height: 100%; object-fit: cover; }
    @media (max-width: 1000px) {
      .hero { flex-direction: column; align-items: flex-start; padding: 40px 20px; }
      .hero-title { font-size: 36px; }
      .hero-photo { order: -1; margin-bottom: 24px; width: 200px; height: 248px; }
    }

    .skills { padding: 45px 155px; }
    .skills-grid { display: grid; grid-template-columns: 2fr 2fr 1fr; gap: 40px; margin-top: 51px; }
    .skill-title { font-family: var(--font-display); font-weight: 600; font-size: 24px; margin: 0 0 29px; font-variation-settings: "SOFT" 0, "WONK" 1; }
    .skill-row { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
    @media (max-width: 900px) {
      .skills { padding: 32px 20px; }
      .skills-grid { grid-template-columns: 1fr; gap: 32px; }
    }
  </style>
</Layout>
