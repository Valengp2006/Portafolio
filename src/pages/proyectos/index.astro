---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { projects } from "../../data/projects";

const order = ["muse", "pasos-de-tradicion", "cosmos", "luna-y-las-estrellas-perdidas"];
const ordered = order.map((slug) => projects.find((p) => p.slug === slug)!);
---

<Layout title="Proyectos — Valentina">
  <Nav active="proyectos" />
  <main>
    <section class="hero">
      <div class="wrap hero-wrap">
        <p class="eyebrow reveal">Trabajo</p>
        <h1 class="hero-title reveal">Proyectos</h1>
        <p class="hero-body reveal">Diseño experiencias donde la interacción se convierte en una forma de contar historias, preservar memorias y acercar a las personas a la tecnología. Mi trabajo combina investigación, diseño y desarrollo para crear proyectos que conectan lo digital con lo cultural, lo participativo y lo humano.</p>
      </div>
    </section>

    <section class="grid-section">
      <div class="wrap grid-wrap">
        {ordered.map((p) => (
          <div class="reveal"><ProjectCard project={p} layout="vertical" /></div>
        ))}
      </div>
    </section>
  </main>
  <Footer />

  <style>
    /* VARIABLES EXACTAS DE FIGMA */
    :root {
      --figma-dark: #1F1B16;
      --figma-muted: #8A837A;
      --figma-soft: #57504A;
      --font-fraunces: 'Fraunces', serif;
      --font-inter: 'Inter', sans-serif;
    }

    /* CONTENEDOR GLOBAL RESPONSIVO */
    .wrap {
      max-width: 1513px;
      margin: 0 auto;
      padding: 45px 155px;
      width: 100%;
      box-sizing: border-box;
    }
    @media (max-width: 1000px) {
      .wrap { padding: 40px 20px; }
    }

    .eyebrow {
      font-family: var(--font-fraunces);
      font-weight: 600;
      font-size: 18px;
      line-height: 26px;
      color: var(--figma-muted);
      margin: 0 0 16px 0;
    }

    /* --- HERO --- */
    .hero-wrap { 
      display: flex; 
      flex-direction: column; 
      align-items: flex-start;
      padding-bottom: 24px; /* Ajuste para equilibrar el espacio con el grid */
    }
    .hero-title { 
      font-family: var(--font-fraunces); 
      font-weight: 400; 
      font-size: 72px; 
      line-height: 72px; 
      color: var(--figma-dark);
      margin: 0 0 42px 0; 
    }
    .hero-body { 
      font-family: var(--font-inter);
      font-size: 18px; 
      line-height: 30px; 
      color: var(--figma-soft); 
      max-width: 860px; 
      margin: 0; 
    }
    
    @media (max-width: 1000px) {
      .hero-title { font-size: 44px; line-height: 50px; margin: 0 0 24px 0; }
    }

    /* --- GRID DE PROYECTOS --- */
    .grid-wrap { 
      display: grid; 
      grid-template-columns: repeat(2, 1fr); 
      gap: 60px 40px; 
      padding-top: 0; 
      padding-bottom: 96px;
    }
    
    @media (max-width: 1000px) {
      .grid-wrap { grid-template-columns: 1fr; gap: 40px; padding-top: 24px; }
    }
  </style>
</Layout>
