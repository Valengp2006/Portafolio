---
interface Props {
  active?: "sobre-mi" | "proyectos" | "servicios" | "contacto" | "";
}
const { active = "" } = Astro.props;

// Mantenemos la ruta base para GitHub Pages
const base = import.meta.env.BASE_URL; 

const getUrl = (path: string) => {
  return `${base}${path}`.replace(/\/\/+/g, '/');
};

const links = [
  { href: getUrl("sobre-mi/"), label: "Sobre mí", key: "sobre-mi" },
  { href: getUrl("proyectos/"), label: "Proyectos", key: "proyectos" },
  { href: getUrl("servicios/"), label: "Servicios", key: "servicios" },
  { href: getUrl("contacto/"), label: "Contacto", key: "contacto" },
];
---
<header class="nav">
  <a href={base} class="nav-name">Valentina</a>
  
  <!-- Agrupamos los enlaces y el idioma en un contenedor derecho -->
  <div class="nav-right">
    <nav class="nav-links">
      {links.map((l) => (
        <a href={l.href} class={active === l.key ? "is-active" : ""}>{l.label}</a>
      ))}
    </nav>
    <div class="nav-lang">ES <span class="nav-lang-dim">/ EN</span></div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--surface-warm);
    border-bottom: 1px solid var(--line);
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 56px;
  }
  .nav-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    color: var(--ink);
    font-variation-settings: "SOFT" 0, "WONK" 1;
  }
  
  /* Nuevo contenedor derecho con flexbox */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 40px; /* Separación entre el menú de enlaces y el ES / EN */
  }

  .nav-lang {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    color: var(--ink-soft);
    /* Eliminamos el position: absolute y el transform */
  }
  .nav-lang-dim { font-weight: 400; }
  
  .nav-links {
    display: flex;
    gap: 31px;
    /* Eliminamos el position: absolute */
  }
  .nav-links a {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 14px;
    color: var(--ink-soft);
  }
  .nav-links a.is-active {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  
  @media (max-width: 900px) {
    .nav-lang { display: none; }
    .nav-links { gap: 16px; }
    .nav { padding: 0 20px; }
  }
</style>
