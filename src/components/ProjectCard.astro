---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  layout: "hero" | "vertical" | "horizontal";
}
const { project: p, layout } = Astro.props;

// 1. Obtenemos la ruta base configurada
const base = import.meta.env.BASE_URL;

// 2. Creamos la función auxiliar para limpiar las barras duplicadas
const getUrl = (path: string) => {
  return `${base}${path}`.replace(/\/\/+/g, '/');
};
---

{layout === "hero" && (
  <a href={getUrl(`/proyectos/${p.slug}/`)} class="card card-hero">
    <img src={p.cover} alt={p.title} class="card-hero-img" loading="lazy" />
    <div class="card-hero-shade"></div>
    <div class="card-hero-content">
      <span class="card-tag" style={`background:${p.tint}; color:${p.textColor};`}>{p.tag}</span>
      <div class="card-hero-text-wrap">
        <div class="card-hero-text">
          <h3 class="card-hero-title">{p.title}</h3>
          <p class="card-hero-desc">{p.result}</p>
        </div>
        <div class="card-hero-icon" aria-hidden="true">↗</div>
      </div>
    </div>
  </a>
)}

{layout === "vertical" && (
  <a href={getUrl(`/proyectos/${p.slug}/`)} class="card card-vertical">
    <img src={p.cover} alt={p.title} class="card-vertical-img" loading="lazy" />
    <div class="card-vertical-body">
      <span class="card-tag" style={`background:${p.tint}; color:${p.textColor};`}>{p.tag}</span>
      <h3 class="card-vertical-title">{p.title}</h3>
      <p class="card-vertical-desc">{p.result}</p>
      <span class="card-link" style={`color:${p.color}`}>Ver proyecto <span aria-hidden="true">↗</span></span>
    </div>
  </a>
)}

{layout === "horizontal" && (
  <a href={getUrl(`/proyectos/${p.slug}/`)} class="card card-horizontal">
    <img src={p.cover} alt={p.title} class="card-horizontal-img" loading="lazy" />
    <div class="card-horizontal-body">
      <span class="card-tag" style={`background:${p.tint}; color:${p.textColor};`}>{p.tag}</span>
      <h3 class="card-horizontal-title">{p.title}</h3>
      <p class="card-horizontal-desc">{p.result}</p>
      <span class="card-link" style={`color:${p.color}`}>Ver proyecto <span aria-hidden="true">↗</span></span>
    </div>
  </a>
)}

<style>
  .card { display: block; position: relative; border-radius: 16px; overflow: hidden; text-decoration: none; }
  
  /* TAGS (Pills) exactos de Figma */
  .card-tag { 
    font-family: 'Inter', sans-serif;
    font-size: 14px; 
    line-height: 22px;
    padding: 5px 10px; 
    border-radius: 100px; /* Bordes completamente redondeados de Figma */
    width: fit-content; /* PREVIENE EL ESTIRAMIENTO HORIZONTAL */
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  /* Hero (MUSE-style full-width dark card) */
  .card-hero { height: 483px; }
  .card-hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .card-hero-shade { 
    position: absolute; 
    inset: 0; 
    background: linear-gradient(180deg, rgba(81, 81, 81, 0) 0%, #1F1B16 93%);
    opacity: 0.9;
  }
  .card-hero-content { 
    position: absolute; 
    inset: 0; 
    display: flex; 
    flex-direction: column; 
    justify-content: flex-end; 
    gap: 16px; 
    padding: 56px; 
  }
  .card-hero-text-wrap {
    display: flex; 
    align-items: flex-end; 
    justify-content: space-between;
    gap: 24px;
  }
  .card-hero-text { 
    display: flex; 
    flex-direction: column; 
    gap: 16px; 
    max-width: 934px;
  }
  .card-hero-title { 
    font-family: 'Fraunces', serif; 
    font-weight: 400; 
    font-size: 56px; 
    line-height: 60px; 
    color: #FAF7F2; 
    margin: 0; 
  }
  .card-hero-desc { 
    font-family: 'Inter', sans-serif;
    font-size: 18px; 
    line-height: 30px;
    color: rgba(250,247,242,0.72); 
    margin: 0; 
  }
  
  /* Botón circular de la card Hero tal como en Figma */
  .card-hero-icon { 
    width: 60px; 
    height: 60px; 
    border-radius: 50%;
    border: 1px solid rgba(250, 247, 242, 0.40);
    display: flex;
    justify-content: center;
    align-items: center;
    color: #FAF7F2;
    font-size: 24px;
    flex-shrink: 0;
  }

  /* Vertical (2-up medium cards) */
  .card-vertical { background: #F5F1EA; border: none; }
  .card-vertical-img { width: 100%; height: 258px; object-fit: cover; }
  .card-vertical-body { padding: 32px; display: flex; flex-direction: column; align-items: flex-start; gap: 16px; }
  .card-vertical-title { 
    font-family: 'Fraunces', serif; 
    font-weight: 400; 
    font-size: 32px; 
    line-height: 40px;
    color: #1F1B16;
    margin: 0; 
  }
  .card-vertical-desc { 
    font-family: 'Inter', sans-serif;
    font-size: 14px; 
    line-height: 22px;
    color: #1F1B16; 
    margin: 0; 
  }

  /* Horizontal (wide 2-column card) */
  .card-horizontal { display: flex; height: 280px; background: #F5F1EA; }
  .card-horizontal-img { width: 50%; height: 100%; object-fit: cover; border-radius: 16px 0 0 16px; }
  .card-horizontal-body { width: 50%; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; gap: 16px; padding: 0 60px; }
  .card-horizontal-title { 
    font-family: 'Fraunces', serif; 
    font-weight: 400; 
    font-size: 32px; 
    line-height: 40px;
    color: #1F1B16;
    margin: 0; 
  }
  .card-horizontal-desc { 
    font-family: 'Inter', sans-serif;
    font-size: 14px; 
    line-height: 22px;
    color: #1F1B16; 
    margin: 0; 
  }

  .card-link { 
    font-family: 'Inter', sans-serif;
    font-size: 14px; 
    font-weight: 500; 
    line-height: 20px;
    display: inline-flex; 
    align-items: center; 
    gap: 4px; 
  }

  @media (max-width: 900px) {
    .card-hero-content { padding: 32px; }
    .card-hero-title, .card-vertical-title, .card-horizontal-title { font-size: 28px; line-height: 36px; }
    .card-horizontal { flex-direction: column; height: auto; }
    .card-horizontal-img, .card-horizontal-body { width: 100%; }
    .card-horizontal-img { border-radius: 16px 16px 0 0; height: 200px; }
    .card-horizontal-body { border-radius: 0 0 16px 16px; padding: 24px; }
  }
</style>
